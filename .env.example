# Workday OAuth 2.0 credentials
# Token endpoint — typically: https://<host>/ccx/oauth2/<tenant>/token
WORKDAY_TOKEN_ENDPOINT=https://wd2.myworkday.com/ccx/oauth2/YOUR_TENANT/token

# SOAP endpoint for the Revenue Management web service
# Format: https://<host>/ccx/service/<tenant>/Revenue_Management/<version>
WORKDAY_SOAP_ENDPOINT=https://wd2.myworkday.com/ccx/service/YOUR_TENANT/Revenue_Management/v46.1

# API Client credentials (from Workday > Register API Client)
WORKDAY_CLIENT_ID=your_client_id_here
WORKDAY_CLIENT_SECRET=your_client_secret_here

# Refresh token (from Workday > Manage Refresh Tokens for Integrations)
WORKDAY_REFRESH_TOKEN=your_refresh_token_here

# Optional overrides (defaults shown)
WORKDAY_API_VERSION=v46.1
PAGE_SIZE=999
MAX_CONCURRENT=5
OUTPUT_DIR=extracts
